# S3 / R2 credentials used by builder.config.ts
S3_BUCKET=replace_with_your_bucket_name
S3_ENDPOINT=https://replace_with_your_s3_endpoint
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace_with_your_s3_access_key
S3_SECRET_ACCESS_KEY=replace_with_your_s3_secret_key
S3_PREFIX=photos/
S3_CUSTOM_DOMAIN=cdn.example.com

# PostgreSQL settings used by docker compose
POSTGRES_DB=afilmory
POSTGRES_USER=afilmory
POSTGRES_PASSWORD=replace_with_a_strong_password

# PostgreSQL connection string used by the app at runtime
# Keep this aligned with POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD above.
PG_CONNECTION_STRING=postgresql://afilmory:replace_with_a_strong_password@postgres:5432/afilmory

# GitHub personal access token used by githubRepoSyncPlugin
GITHUB_REPO_URL=https://github.com/your-org/your-repo
GITHUB_REPO_BRANCH=main
GIT_TOKEN=replace_with_your_github_token
